def get_match_score(char1, char2, matrix):
    return matrix.get(char1 + char2, matrix.get(char2 + char1, 0))


def create_empty_matrix(rows, cols):
    F = [[0 for _ in range(cols + 1)] for _ in range(rows + 1)]
    P = [['' for _ in range(cols + 1)] for _ in range(rows + 1)]
    return F, P


# --- 2. GLOBAL ALIGNMENT (NEEDLEMAN-WUNSCH) ---
def global_init(F, P, rows, cols, gap):
    for i in range(1, rows + 1):
        F[i][0] = i * gap
        P[i][0] = 'u'
    for j in range(1, cols + 1):
        F[0][j] = j * gap
        P[0][j] = 'l'
    return F, P


def global_fill(seq1, seq2, F, P, matrix, gap):
    for i in range(1, len(seq1) + 1):
        for j in range(1, len(seq2) + 1):
            match = get_match_score(seq1[i - 1], seq2[j - 1], matrix)
            diag = F[i - 1][j - 1] + match
            up = F[i - 1][j] + gap
            left = F[i][j - 1] + gap

            F[i][j] = max(diag, up, left)
            if F[i][j] == diag:
                P[i][j] = 'd'
            elif F[i][j] == up:
                P[i][j] = 'u'
            else:
                P[i][j] = 'l'
    return F, P


def global_backtrack(seq1, seq2, F, P):
    aln1, aln2 = '', ''
    i, j = len(seq1), len(seq2)
    score = F[i][j]
    while P[i][j] != '':
        if P[i][j] == 'd':
            aln1 = seq1[i - 1] + aln1;
            aln2 = seq2[j - 1] + aln2
            i -= 1;
            j -= 1
        elif P[i][j] == 'l':
            aln1 = '-' + aln1;
            aln2 = seq2[j - 1] + aln2
            j -= 1
        elif P[i][j] == 'u':
            aln1 = seq1[i - 1] + aln1;
            aln2 = '-' + aln2
            i -= 1
    return aln1, aln2, score


# --- 3. LOCAL ALIGNMENT (SMITH-WATERMAN) ---
def local_fill(seq1, seq2, F, P, matrix, gap):
    # Local init zaten create_empty_matrix ile 0 gelmişti, extra bir şey gerekmez.
    for i in range(1, len(seq1) + 1):
        for j in range(1, len(seq2) + 1):
            match = get_match_score(seq1[i - 1], seq2[j - 1], matrix)
            diag = F[i - 1][j - 1] + match
            up = F[i - 1][j] + gap
            left = F[i][j - 1] + gap

            F[i][j] = max(0, diag, up, left)

            if F[i][j] == 0:
                P[i][j] = ''  # Durma noktası
            elif F[i][j] == diag:
                P[i][j] = 'd'
            elif F[i][j] == up:
                P[i][j] = 'u'
            else:
                P[i][j] = 'l'
    return F, P


def local_backtrack(seq1, seq2, F, P):
    aln1, aln2 = '', ''
    # En yüksek puanı bul
    max_score = -1
    start_i, start_j = 0, 0
    for r in range(len(seq1) + 1):
        for c in range(len(seq2) + 1):
            if F[r][c] > max_score:
                max_score, start_i, start_j = F[r][c], r, c

    i, j = start_i, start_j
    while P[i][j] != '':
        if P[i][j] == 'd':
            aln1 = seq1[i - 1] + aln1;
            aln2 = seq2[j - 1] + aln2
            i -= 1;
            j -= 1
        elif P[i][j] == 'l':
            aln1 = '-' + aln1;
            aln2 = seq2[j - 1] + aln2
            j -= 1
        elif P[i][j] == 'u':
            aln1 = seq1[i - 1] + aln1;
            aln2 = '-' + aln2
            i -= 1
    return aln1, aln2, max_score


# --- 4. ANA PROGRAM ---
def main():
    template = "LLALWGPDPAAAFVNQHLCGSHLVEALYLVCGERGFFYTPKTRREAEDLQVGQVELGGGPGAGSLQPLALEGSLQKRGIVEQCCTSICSLYQLENYCN"
    target = "MALWMRLLPLLALLALWGPDPVPAFVNQHLCGSHLVEALYLVCGERGFFYTPKTRREAEDPQVGQVELGGGPGTGSLQPLALEGSLQKRGIVEQCCTSICSLYQLENYCN"
    gap = -2
    mode = sys.argv[1].lower() if len(sys.argv) > 1 else "global"

    pam = get_pam250()
    F, P = create_empty_matrix(len(target), len(template))

    if mode == "global":
        F, P = global_init(F, P, len(target), len(template), gap)
        F, P = global_fill(target, template, F, P, pam, gap)
        a1, a2, score = global_backtrack(target, template, F, P)
    else:
        F, P = local_fill(target, template, F, P, pam, gap)
        a1, a2, score = local_backtrack(target, template, F, P)

    print(f"[{mode.upper()}] Skor: {score}\nAln1: {a1}\nAln2: {a2}")


if __name__ == "__main__":
    main()
